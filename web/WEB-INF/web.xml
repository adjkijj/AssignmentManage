<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Assignment Management System</display-name>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== FILTERS ==================== -->

    <!-- Authentication Filter -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Authorization Filter -->
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== SERVLETS ==================== -->

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Dashboard Servlet -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Assignment Servlet -->
    <servlet>
        <servlet-name>AssignmentServlet</servlet-name>
        <servlet-class>controller.AssignmentServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>
            <max-request-size>52428800</max-request-size>
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>AssignmentServlet</servlet-name>
        <url-pattern>/assignments</url-pattern>
    </servlet-mapping>

    <!-- Submission Servlet -->
    <servlet>
        <servlet-name>SubmissionServlet</servlet-name>
        <servlet-class>controller.SubmissionServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>
            <max-request-size>52428800</max-request-size>
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmissionServlet</servlet-name>
        <url-pattern>/submissions</url-pattern>
    </servlet-mapping>

    <!-- Comment Servlet -->
    <servlet>
        <servlet-name>CommentServlet</servlet-name>
        <servlet-class>controller.CommentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CommentServlet</servlet-name>
        <url-pattern>/comments</url-pattern>
    </servlet-mapping>

    <!-- Admin Dashboard Servlet -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>controller.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Admin Audit Log Servlet -->
    <servlet>
        <servlet-name>AuditLogServlet</servlet-name>
        <servlet-class>controller.AuditLogServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuditLogServlet</servlet-name>
        <url-pattern>/admin/audit-log</url-pattern>
    </servlet-mapping>

    <!-- Admin User Servlet -->
    <servlet>
        <servlet-name>AdminUserServlet</servlet-name>
        <servlet-class>controller.AdminUserServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <!-- Admin Edit User Servlet -->
    <servlet>
        <servlet-name>EditUserServlet</servlet-name>
        <servlet-class>controller.EditUserServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditUserServlet</servlet-name>
        <url-pattern>/admin/edit-user</url-pattern>
    </servlet-mapping>

    <!-- Admin Course Servlet -->
    <servlet>
        <servlet-name>AdminCourseServlet</servlet-name>
        <servlet-class>controller.AdminCourseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminCourseServlet</servlet-name>
        <url-pattern>/admin/courses</url-pattern>
    </servlet-mapping>

    <!-- Admin Course Detail Servlet -->
    <servlet>
        <servlet-name>CourseDetailServlet</servlet-name>
        <servlet-class>controller.CourseDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CourseDetailServlet</servlet-name>
        <url-pattern>/admin/course-detail</url-pattern>
    </servlet-mapping>

    <!-- Admin Enrollment Servlet -->
    <servlet>
        <servlet-name>AdminEnrollmentServlet</servlet-name>
        <servlet-class>controller.AdminEnrollmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminEnrollmentServlet</servlet-name>
        <url-pattern>/admin/enrollments</url-pattern>
    </servlet-mapping>

    <!-- Import Users Servlet (CSV Bulk Import) -->
    <servlet>
        <servlet-name>ImportUsersServlet</servlet-name>
        <servlet-class>controller.ImportUsersServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size>
            <max-request-size>10485760</max-request-size>
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImportUsersServlet</servlet-name>
        <url-pattern>/admin/import-users</url-pattern>
    </servlet-mapping>

    <!-- Notification Servlet -->
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>controller.NotificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotificationServlet</servlet-name>
        <url-pattern>/notifications</url-pattern>
    </servlet-mapping>

    <!-- Group Servlet -->
    <servlet>
        <servlet-name>GroupServlet</servlet-name>
        <servlet-class>controller.GroupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GroupServlet</servlet-name>
        <url-pattern>/groups</url-pattern>
    </servlet-mapping>

    <!-- Admin Semester Servlet -->
    <servlet>
        <servlet-name>AdminSemesterServlet</servlet-name>
        <servlet-class>controller.AdminSemesterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminSemesterServlet</servlet-name>
        <url-pattern>/admin/semesters</url-pattern>
    </servlet-mapping>

    <!-- Admin Subject Servlet -->
    <servlet>
        <servlet-name>AdminSubjectServlet</servlet-name>
        <servlet-class>controller.AdminSubjectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminSubjectServlet</servlet-name>
        <url-pattern>/admin/subjects</url-pattern>
    </servlet-mapping>

    <!-- Student Enroll Servlet -->
    <servlet>
        <servlet-name>StudentEnrollServlet</servlet-name>
        <servlet-class>controller.StudentEnrollServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentEnrollServlet</servlet-name>
        <url-pattern>/student/enroll</url-pattern>
    </servlet-mapping>

    <!-- Student Course Servlet (My Classes) -->
    <servlet>
        <servlet-name>StudentCourseServlet</servlet-name>
        <servlet-class>controller.StudentCourseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentCourseServlet</servlet-name>
        <url-pattern>/student/courses</url-pattern>
    </servlet-mapping>

    <!-- Instructor Course Servlet (My Managed Classes) -->
    <servlet>
        <servlet-name>InstructorCourseServlet</servlet-name>
        <servlet-class>controller.InstructorCourseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InstructorCourseServlet</servlet-name>
        <url-pattern>/instructor/courses</url-pattern>
    </servlet-mapping>
    <!-- Forgot Password Servlet -->
    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>controller.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>

    <!-- Reset Password Servlet -->
    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>controller.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/reset-password</url-pattern>
    </servlet-mapping>

    <!-- Change Password Servlet -->
    <servlet>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <servlet-class>controller.ChangePasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <url-pattern>/change-password</url-pattern>
    </servlet-mapping>

    <!-- Course Material Servlet (Feature 3) -->
    <servlet>
        <servlet-name>CourseMaterialServlet</servlet-name>
        <servlet-class>controller.CourseMaterialServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>
            <max-request-size>52428800</max-request-size>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>CourseMaterialServlet</servlet-name>
        <url-pattern>/course-materials</url-pattern>
    </servlet-mapping>

    <!-- Gradebook Servlet (Feature 7) -->
    <servlet>
        <servlet-name>GradebookServlet</servlet-name>
        <servlet-class>controller.GradebookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GradebookServlet</servlet-name>
        <url-pattern>/gradebook</url-pattern>
    </servlet-mapping>

    <!-- Export Servlet (Feature 9) -->
    <servlet>
        <servlet-name>ExportServlet</servlet-name>
        <servlet-class>controller.ExportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExportServlet</servlet-name>
        <url-pattern>/export</url-pattern>
    </servlet-mapping>

    <!-- Rubric Servlet (Feature 5) -->
    <servlet>
        <servlet-name>RubricServlet</servlet-name>
        <servlet-class>controller.RubricServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RubricServlet</servlet-name>
        <url-pattern>/rubric</url-pattern>
    </servlet-mapping>

    <!-- Statistics Servlet (Feature 8) -->
    <servlet>
        <servlet-name>StatisticsServlet</servlet-name>
        <servlet-class>controller.StatisticsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StatisticsServlet</servlet-name>
        <url-pattern>/statistics</url-pattern>
    </servlet-mapping>

    <!-- Announcement Servlet (Feature 9) -->
    <servlet>
        <servlet-name>AnnouncementServlet</servlet-name>
        <servlet-class>controller.AnnouncementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnnouncementServlet</servlet-name>
        <url-pattern>/announcements</url-pattern>
    </servlet-mapping>

    <!-- File Servlet (serves uploaded files from disk) -->
    <servlet>
        <servlet-name>FileServlet</servlet-name>
        <servlet-class>controller.FileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileServlet</servlet-name>
        <url-pattern>/uploads/*</url-pattern>
    </servlet-mapping>

    <!-- ==================== SESSION CONFIG ==================== -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ==================== JSP CONFIG (Custom Tags) ==================== -->
    <jsp-config>
        <taglib>
            <taglib-uri>http://assignmentmanage/customtags</taglib-uri>
            <taglib-location>/WEB-INF/tags/customtags.tld</taglib-location>
        </taglib>
    </jsp-config>

</web-app>
